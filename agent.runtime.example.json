{
  "cloudflaredPath": "${CLOUDFLARED_PATH}",
  "loopIntervalMs": 5000,
  "localLogPath": ".\\logs\\school-services.log",
  "localLogMaxBytes": 5242880,
  "startup": {
    "mode": "clean-online"
  },
  "tunnel": {
    "mode": "quick",
    "startSpacingMs": 5000,
    "globalCooldownMs": 60000,
    "startupTimeoutMs": 30000,
    "retryDelaysMs": [10000, 30000, 60000, 120000, 300000]
  },
  "guestPortal": {
    "baseUrl": "https://school-services.netlify.app",
    "fileName": "School Services.url",
    "iconFile": ".\\favicon.ico",
    "iconIndex": 0,
    "filePaths": [
      "${OneDrive}\\Desktop\\School Services.url",
      "${USERPROFILE}\\OneDrive\\Desktop\\School Services.url",
      "${USERPROFILE}\\Desktop\\School Services.url",
      "C:\\Users\\Public\\Desktop\\School Services.url"
    ]
  },
  "services": {
    "rapor": {
      "startOrder": 10,
      "autoStart": true,
      "startStrategy": "windows-service",
      "stopStrategy": "windows-service",
      "windowsServices": [],
      "windowsServiceDiscovery": {
        "includeAny": ["rapor"],
        "excludeAny": ["dapodik"],
        "preferAny": ["db", "srv", "service"],
        "expectedCount": 2
      },
      "needsConfigUpdate": true,
      "configTargets": [
        {
          "targetId": "rapor-root-env",
          "type": "env",
          "path": "${ERAPOR_ROOT}\\.env",
          "pathCandidates": [
            "${ERAPOR_ROOT}\\.env",
            "C:\\newappraporsd2025\\.env",
            "C:\\E-Rapor\\.env",
            "C:\\erapor\\.env"
          ],
          "key": "app.baseURL"
        },
        {
          "targetId": "rapor-wwwroot-env",
          "type": "env",
          "path": "${ERAPOR_ROOT}\\wwwroot\\.env",
          "pathCandidates": [
            "${ERAPOR_ENV_PATH}",
            "${ERAPOR_ROOT}\\wwwroot\\.env",
            "C:\\newappraporsd2025\\wwwroot\\.env",
            "C:\\E-Rapor\\wwwroot\\.env",
            "C:\\erapor\\wwwroot\\.env"
          ],
          "key": "app.baseURL"
        }
      ],
      "key": "app.baseURL"
    },
    "dapodik": {
      "startOrder": 20,
      "autoStart": true,
      "startStrategy": "windows-service",
      "stopStrategy": "windows-service",
      "windowsServices": [],
      "windowsServiceDiscovery": {
        "includeAny": ["dapodik"],
        "preferAny": ["db", "web", "srv", "service"],
        "expectedCount": 2
      },
      "needsConfigUpdate": false
    }
  },
  "supabase": {
    "url": "${SUPABASE_URL}",
    "anonKey": "${SUPABASE_ANON_KEY}"
  }
}
