{
  "name": "e-rapor-control-plane",
  "private": true,
  "workspaces": [
    "agent",
    "web-app"
  ],
  "scripts": {
    "agent:dev": "npm --workspace agent run dev",
    "agent:build": "npm --workspace agent run build",
    "dashboard:dev": "npm --workspace web-app run dev",
    "dashboard:build": "npm --workspace web-app run build",
    "web-app:dev": "npm --workspace web-app run dev",
    "web-app:build": "npm --workspace web-app run build",
    "supabase:apply": "node scripts/supabase-orchestrator.mjs apply",
    "supabase:verify": "node scripts/supabase-orchestrator.mjs verify",
    "supabase:seed-admin": "node scripts/supabase-orchestrator.mjs seed-admin",
    "supabase:deploy-functions": "node scripts/supabase-orchestrator.mjs deploy-functions"
  },
  "devDependencies": {
    "supabase": "^2.95.3"
  }
}
