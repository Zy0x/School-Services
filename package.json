{
  "name": "e-rapor-control-plane",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "agent"
  ],
  "scripts": {
    "agent:dev": "npm --workspace agent run dev",
    "agent:build": "npm --workspace agent run build",
    "frontend:dev": "npm --workspace @erapor/frontend run dev",
    "frontend:build": "npm --workspace @erapor/frontend run build",
    "frontend:preview": "npm --workspace @erapor/frontend run preview -- --host 127.0.0.1 --port 4173",
    "backend:dev": "npm --workspace @erapor/backend run dev",
    "backend:start": "npm --workspace @erapor/backend run start",
    "backend:build": "npm --workspace @erapor/backend run build",
    "dashboard:dev": "npm run frontend:dev",
    "dashboard:build": "npm run frontend:build",
    "dashboard:preview": "npm run frontend:preview",
    "web-app:dev": "npm run frontend:dev",
    "web-app:build": "npm run frontend:build",
    "web-app:preview": "npm run frontend:preview",
    "dev": "npm run frontend:dev",
    "build": "npm run frontend:build && npm run backend:build",
    "supabase:apply": "node scripts/supabase-orchestrator.mjs apply",
    "supabase:verify": "node scripts/supabase-orchestrator.mjs verify",
    "supabase:seed-admin": "node scripts/supabase-orchestrator.mjs seed-admin",
    "supabase:deploy-functions": "node scripts/supabase-orchestrator.mjs deploy-functions",
    "supabase:reset-admin": "node scripts/reset-superadmin-password.mjs"
  },
  "devDependencies": {
    "supabase": "^2.95.3"
  },
  "version": "2.0.4"
}
